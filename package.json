{
  "name": "pi-chi",
  "version": "0.1.2",
  "private": true,
  "description": "Autonomous AI agent system for Raspberry Pi — full system control, GPIO, self-directed goals",
  "scripts": {
    "dev": "next dev --port 3333",
    "build": "next build",
    "start": "next start --port 3333",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky",
    "brain": "tsx scripts/pi-brain.ts",
    "brain:dev": "tsx watch scripts/pi-brain.ts",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/react": "^3.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@serialport/parser-readline": "^13.0.0",
    "@supabase/supabase-js": "^2.97.0",
    "@webcontainer/api": "^1.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ai": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.7",
    "framer-motion": "^12.12.1",
    "jose": "^6.1.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.55.0",
    "next": "^15.3.3",
    "pg": "^8.18.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^3.0.2",
    "serialport": "^13.0.0",
    "sonner": "^2.0.3",
    "tailwind-merge": "^3.3.0",
    "v0-sdk": "^0.16.2",
    "stripe": "^17.5.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "bash -c 'npx tsc --noEmit --pretty'"
  }
